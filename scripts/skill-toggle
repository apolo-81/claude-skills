#!/usr/bin/env bash
# skill-toggle — Activar/desactivar grupos de skills de Claude Code
# Uso: skill-toggle <grupo> <on|off|status>
# Ejemplos:
#   skill-toggle seo off       # Desactiva todas las skills de SEO
#   skill-toggle market off    # Desactiva todas las de marketing
#   skill-toggle dev on        # Activa todas las de desarrollo
#   skill-toggle all status    # Muestra estado de todas
#   skill-toggle list          # Lista grupos disponibles

SKILLS_DIR="$HOME/.claude/skills"

# ─── Definición de grupos ──────────────────────────────────────────────────
unset GROUPS
declare -A GROUPS
GROUPS[audit]="seo-core seo-content-onpage seo-international seo-strategy seo-assets market-audit market-competitors market-funnel market-social market-ads market-report market-report-pdf"
GROUPS[market]="market market-ads market-audit market-brand market-competitors market-copy market-emails market-funnel market-landing market-launch market-proposal market-report market-report-pdf market-social"
GROUPS[dev]="form-handling performance-next error-monitoring testing-patterns supabase-stack saas-boilerplate webhook-integration"
GROUPS[n8n]="n8n-ai-agents n8n-to-api"
GROUPS[design]="ui-designer web-animations pro-presentations landing-page-builder data-viz-dashboard email-templates-builder"
GROUPS[web]="cms-integration pwa-patterns"
GROUPS[all]="${GROUPS[audit]} ${GROUPS[dev]} ${GROUPS[n8n]} ${GROUPS[design]} ${GROUPS[web]}"

# ─── Colores ────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# ─── Funciones ──────────────────────────────────────────────────────────────
show_help() {
    echo "skill-toggle — Activar/desactivar skills de Claude Code por grupo"
    echo ""
    echo "Uso: skill-toggle <grupo> <on|off|status>"
    echo "      skill-toggle list"
    echo "      skill-toggle status"
    echo ""
    echo "Grupos disponibles:"
    echo "  seo      — 5 skills de SEO"
    echo "  market   — 14 skills de Marketing"
    echo "  dev      — 7 skills de Desarrollo"
    echo "  audit    — 12 skills de Market & SEO Audit (bajo demanda)
  n8n      — 2 skills de N8N/Automatización"
    echo "  design   — 5 skills de Diseño/UI"
    echo "  web      — 2 skills de CMS/PWA"
    echo "  all      — Todas las skills (33)"
    echo ""
    echo "Ejemplos:"
    echo "  skill-toggle seo off       Desactivar SEO"
    echo "  skill-toggle dev on        Activar Desarrollo"
    echo "  skill-toggle status        Ver estado de todo"
}

toggle_skill() {
    local skill="$1"
    local action="$2"
    local skill_file="$SKILLS_DIR/$skill/SKILL.md"
    local disabled_file="$SKILLS_DIR/$skill/SKILL.md.off"

    if [ "$action" = "off" ]; then
        if [ -f "$skill_file" ]; then
            mv "$skill_file" "$disabled_file"
            echo -e "  ${RED}OFF${NC}  $skill"
        else
            echo -e "  ${RED}OFF${NC}  $skill (ya estaba off)"
        fi
    elif [ "$action" = "on" ]; then
        if [ -f "$disabled_file" ]; then
            mv "$disabled_file" "$skill_file"
            echo -e "  ${GREEN}ON ${NC}  $skill"
        else
            echo -e "  ${GREEN}ON ${NC}  $skill (ya estaba on)"
        fi
    fi
}

show_status() {
    local group="$1"
    local skills="${GROUPS[$group]}"
    local on=0
    local off=0

    echo -e "${BLUE}[$group]${NC}"
    for skill in $skills; do
        if [ -f "$SKILLS_DIR/$skill/SKILL.md" ]; then
            echo -e "  ${GREEN}ON ${NC}  $skill"
            ((on++))
        elif [ -f "$SKILLS_DIR/$skill/SKILL.md.off" ]; then
            echo -e "  ${RED}OFF${NC}  $skill"
            ((off++))
        else
            echo -e "  ${YELLOW}??? ${NC} $skill (no encontrada)"
        fi
    done
    echo -e "  ${GREEN}$on on${NC} / ${RED}$off off${NC}"
    echo ""
}

# ─── Main ───────────────────────────────────────────────────────────────────
case "${1:-help}" in
    help|--help|-h)
        show_help
        ;;
    list)
        echo "Grupos disponibles:"
        for group in audit dev n8n design web; do
            count=$(echo "${GROUPS[$group]}" | wc -w)
            echo "  $group ($count skills)"
        done
        ;;
    status)
        if [ -z "$2" ]; then
            for group in audit dev n8n design web; do
                show_status "$group"
            done
        else
            show_status "$2"
        fi
        ;;
    *)
        group="$1"
        action="$2"

        if [ -z "${GROUPS[$group]}" ]; then
            echo "Error: grupo '$group' no existe"
            echo "Usa 'skill-toggle list' para ver grupos disponibles"
            exit 1
        fi

        if [ "$action" != "on" ] && [ "$action" != "off" ]; then
            show_status "$group"
            exit 0
        fi

        skills="${GROUPS[$group]}"
        count=$(echo "$skills" | wc -w)

        if [ "$action" = "off" ]; then
            echo -e "${YELLOW}Desactivando $count skills del grupo '$group'...${NC}"
        else
            echo -e "${GREEN}Activando $count skills del grupo '$group'...${NC}"
        fi

        for skill in $skills; do
            toggle_skill "$skill" "$action"
        done

        # Resumen final
        echo ""
        active=$(find "$SKILLS_DIR" -name "SKILL.md" -not -name "*.off" | wc -l)
        inactive=$(find "$SKILLS_DIR" -name "SKILL.md.off" | wc -l)
        echo -e "Total: ${GREEN}$active activas${NC} / ${RED}$inactive inactivas${NC}"
        ;;
esac
